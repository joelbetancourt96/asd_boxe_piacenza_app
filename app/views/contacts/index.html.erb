<%= render "shared/hero_section",
  title: "",
  subtitle: "",
  image_url: image_url("about_us.jpeg") %>

<!-- Black Contact Info Section -->
<section class="bg-white py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Title -->
    <div class="mb-12">
      <h2 class="mb-4 text-4xl font-black tracking-tight text-black">CONTATTACI</h2>
      <div class="h-3 w-56 bg-gradient-to-r from-red-600 via-red-500 to-transparent"></div>
    </div>

    <!-- Contact Info Grid -->
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Address -->
      <a href="https://www.google.com/maps/search/?api=1&query=<%= u("#{@gym_info.gym_address}, #{@gym_info.zip_code} #{@gym_info.city}") %>" target="_blank" rel="noopener noreferrer" class="group flex flex-col items-center rounded-lg bg-[#ee1D23] p-8 transition hover:bg-zinc-800">
        <svg class="mb-4 h-12 w-12 text-white transition group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <h3 class="mb-2 text-lg font-bold text-white group-hover:text-red-500">Indirizzo</h3>
        <p class="text-center text-slate-200 group-hover:text-red-500"><%= @gym_info.gym_address %>, <%= @gym_info.zip_code %> <%= @gym_info.city %></p>
      </a>

      <!-- Phone -->
      <a href="tel:<%= @gym_info.mobile_phone %>" class="group flex flex-col items-center rounded-lg bg-[#ee1D23] p-8 transition hover:bg-zinc-800">
        <svg class="mb-4 h-12 w-12 text-white transition group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
      </svg>
        <h3 class="mb-2 text-lg font-bold text-white group-hover:text-red-500">Telefono</h3>
        <p class="text-center text-slate-200 group-hover:text-red-500"><%= @gym_info.mobile_phone %></p>
      </a>

      <!-- Email -->
      <a href="mailto:<%= @gym_info.info_email %>" class="group flex flex-col items-center rounded-lg bg-[#ee1D23] p-8 transition hover:bg-zinc-800">
        <svg class="mb-4 h-12 w-12 text-white transition group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        <h3 class="mb-2 text-lg font-bold text-white group-hover:text-red-500">Email</h3>
        <p class="text-center text-slate-200 group-hover:text-red-500"><%= @gym_info.info_email %></p>
      </a>
    </div>
  </div>
</section>

<!-- Contact Form Section -->
<section class="bg-white py-16">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <!-- Title -->
    <div class="mb-12 text-center">
      <h2 class="mb-4 text-4xl font-black tracking-tight text-black"> OPPURE COMPILA IL MODULO</h2>
      <h2 class="mb-4 text-4xl font-black tracking-tight text-black"> TI CONTATTEREMO NOI</h2>
      <!-- Red Gradient Line -->
      <div class="mx-24 h-3 w-125 bg-gradient-to-r from-red-600 via-red-500 to-transparent"></div>
    </div>

    <!-- Form -->
    <form class="space-y-8" action="#" method="post">
      <!-- Name and Surname -->
      <div class="grid gap-4 md:grid-cols-2">
        <div class="flex flex-col">
          <label for="first_name" class="mb-2 text-sm font-semibold text-black">Nome</label>
          <input
            type="text"
            id="first_name"
            name="first_name"
            placeholder="Il tuo nome"
            required
            class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-black placeholder-zinc-500 transition focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500"
          />
        </div>
        <div class="flex flex-col">
          <label for="last_name" class="mb-2 text-sm font-semibold text-black">Cognome</label>
          <input
            type="text"
            id="last_name"
            name="last_name"
            placeholder="Il tuo cognome"
            required
            class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-black placeholder-zinc-500 transition focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500"
          />
        </div>
      </div>

      <!-- Email -->
      <div class="flex flex-col">
        <label for="email" class="mb-2 text-sm font-semibold text-black">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="La tua email"
          required
          class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-black placeholder-zinc-500 transition focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500"
        />
      </div>

      <!-- Message -->
      <div class="flex flex-col">
        <label for="message" class="mb-2 text-sm font-semibold text-black">Messaggio</label>
        <textarea
          id="message"
          name="message"
          rows="6"
          placeholder="Il tuo messaggio..."
          class="rounded-lg border border-zinc-300 bg-white px-4 py-3 text-black placeholder-zinc-500 transition focus:border-red-500 focus:outline-none focus:ring-1 focus:ring-red-500"
        ></textarea>
      </div>

      <!-- Privacy Policy -->
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="privacy"
          name="privacy"
          required
          class="mt-1 h-5 w-5 cursor-pointer rounded border-zinc-300 bg-white text-red-500 transition focus:ring-red-500 accent-red-500"
        />
        <label for="privacy" class="text-sm text-zinc-700">
          Accetto il trattamento dei dati personali secondo la
          <a href="#" class="font-semibold text-red-500 hover:underline">Privacy Policy</a>
        </label>
      </div>

      <!-- Submit Button -->
      <button
        type="submit"
        class="w-full rounded-full bg-[#ee1D23] px-8 py-3 text-base font-bold text-white shadow-lg shadow-red-500/20 transition hover:bg-red-700 hover:shadow-lg hover:shadow-red-600/30"
      >
        Invia Messaggio
      </button>
    </form>
  </div>
</section>
