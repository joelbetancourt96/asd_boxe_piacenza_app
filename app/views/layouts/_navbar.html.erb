<header class="bg-[#ee1D23] text-white w-full border-b border-zinc-800">
  <div class="flex items-stretch justify-between px-6 lg:px-10 h-24 md:h-32">
    <div class="flex items-stretch gap-10 lg:gap-12">
      <div class="flex items-stretch bg-[#ee1D23]">
        <%= link_to root_path, class: "flex items-center h-full py-2" do %>
          <%= image_tag "logo_app.jpg", alt: "ASD Boxe Piacenza Logo", class: "h-full w-auto object-contain" %>
        <% end %>
      </div>
      <nav class="hidden items-center gap-10 lg:gap-12 text-lg font-black uppercase tracking-widest md:flex">
        <%= link_to "Home", root_path, class: "hover:text-black transition-colors whitespace-nowrap" %>
        <%= link_to "Chi siamo", about_path, class: "hover:text-black transition-colors whitespace-nowrap" %>
        <%= link_to "Abbonamenti", "#abbonamenti", class: "hover:text-black transition-colors whitespace-nowrap" %>
        <%= link_to "Corsi", courses_path, class: "hover:text-black transition-colors whitespace-nowrap" %>
        <%= link_to "Contatti", "#contatti", class: "hover:text-black transition-colors whitespace-nowrap" %>
        <%= link_to "Pugili", "#boxeurs", class: "hover:text-black transition-colors whitespace-nowrap" %>
      </nav>
    </div>
    <div class="flex items-center">
      <%= link_to "Accedi / Registrati", "#", class: "rounded-full border-2 border-white bg-white px-8 py-3 text-lg font-bold text-black transition hover:bg-transparent hover:text-white whitespace-nowrap" %>
    </div>
  </div>
</header>