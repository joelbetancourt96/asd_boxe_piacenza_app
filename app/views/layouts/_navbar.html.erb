<header class="bg-black text-white">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-10">
      <%= link_to root_path, class: "flex items-center" do %>
        <%= image_tag "logo_app.jpg", alt: "ASD Boxe Piacenza Logo", class: "h-12 w-auto" %>
      <% end %>
      <nav class="hidden gap-8 text-sm font-medium md:flex">
        <%= link_to "Home", root_path, class: "hover:text-slate-200" %>
        <%= link_to "Chi siamo", aboutus_path, class: "hover:text-slate-200" %>
        <%= link_to "Abbonamenti", "#abbonamenti", class: "hover:text-slate-200" %>
        <%= link_to "Corsi", "#courses", class: "hover:text-slate-200" %>
        <%= link_to "Contatti", "#contatti", class: "hover:text-slate-200" %>
        <%= link_to "Pugili", "#boxeurs", class: "hover:text-slate-200" %>
      </nav>
    </div>

    <div class="flex items-center">
      <%= link_to "Accedi / Registrati", "#", class: "rounded-full border border-white bg-white px-5 py-2 text-sm font-semibold text-black transition hover:bg-slate-100" %>
    </div>
  </div>
</header>
