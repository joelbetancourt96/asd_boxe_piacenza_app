<%= render "shared/hero_section",
    image_url: asset_path("about_us.jpeg"),
    title: "I NOSTRI PUGILI",
    subtitle: "ATLETI AGONISTI",
    description: "Conosci i nostri campioni di boxe",
    button_text: "",
    button_link: "" %>

<section id="boxers-section" class="bg-slate-50 py-16 text-black">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-12">
      <h2 class="mb-4 text-4xl font-black tracking-tight text-black">I NOSTRI PUGILI</h2>
      <div class="h-3 w-24 bg-gradient-to-r from-red-600 via-red-500 to-transparent"></div>
    </div>

    <!-- Vue.js Boxers App Mount Point -->
    <div id="boxers-list"></div>
  </div>
</section>

<script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
<script>
  const { createApp } = window.Vue;

  document.addEventListener("DOMContentLoaded", () => {
    const boxersList = document.getElementById("boxers-list");
    if (boxersList) {
      createApp({
        data() {
          return {
            boxers: [],
            loading: true,
            error: null
          }
        },
        computed: {
          groupedBoxers() {
            return this.boxers.reduce((acc, boxer) => {
              if (!acc[boxer.category]) {
                acc[boxer.category] = [];
              }
              acc[boxer.category].push(boxer);
              return acc;
            }, {});
          }
        },
        methods: {
          async fetchBoxers() {
            try {
              this.loading = true;
              const response = await fetch("/boxers.json");
              if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
              }
              this.boxers = await response.json();
              this.error = null;
            } catch (error) {
              console.error("Error fetching boxers:", error);
              this.error = "Errore nel caricamento dei pugili";
            } finally {
              this.loading = false;
            }
          }
        },
        mounted() {
          this.fetchBoxers();
        },
        template: `
          <div v-if="loading" class="text-center py-12">
            <p class="text-xl text-slate-600">Caricamento pugili...</p>
          </div>
          <div v-else-if="error" class="text-center py-12">
            <p class="text-xl text-red-600">{{ error }}</p>
          </div>
          <div v-else>
            <div class="grid gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5">
              <div v-for="boxer in boxers" :key="boxer.id" class="group overflow-hidden rounded-lg bg-white shadow-md transition hover:shadow-lg">
                <!-- Image Section -->
                <div class="relative aspect-[4/3] overflow-hidden bg-gray-900">
                  <img :src="boxer.image_url" :alt="boxer.first_name + ' ' + boxer.last_name" class="h-full w-full object-cover transition group-hover:scale-105">
                  <!-- Category Badge -->
                  <div class="absolute right-2 top-2 rounded-full bg-black/70 px-2 py-1 text-xs font-bold uppercase text-white backdrop-blur-sm">
                    {{ boxer.category }}
                  </div>
                </div>

                <!-- Name Section (Black Background) -->
                <div class="bg-black px-3 py-3 text-white">
                  <p class="text-xs font-semibold">{{ boxer.first_name }}</p>
                  <h3 class="text-lg font-black uppercase text-slate-400">{{ boxer.last_name }}</h3>
                </div>

                <!-- Record Grid (V, P, S) -->
                <div class="grid grid-cols-3 gap-1 bg-slate-100 px-3 py-2">
                  <!-- V (Wins - Green) -->
                  <div class="rounded bg-slate-800 px-2 py-2 text-center">
                    <p class="text-xs font-semibold uppercase text-slate-400">V</p>
                    <p class="text-xl font-black text-green-400">{{ boxer.wins }}</p>
                  </div>
                  <!-- P (Draws - Yellow) -->
                  <div class="rounded bg-slate-800 px-2 py-2 text-center">
                    <p class="text-xs font-semibold uppercase text-slate-400">P</p>
                    <p class="text-xl font-black text-yellow-400">{{ boxer.draws }}</p>
                  </div>
                  <!-- S (Losses - Red) -->
                  <div class="rounded bg-slate-800 px-2 py-2 text-center">
                    <p class="text-xs font-semibold uppercase text-slate-400">S</p>
                    <p class="text-xl font-black text-red-400">{{ boxer.losses }}</p>
                  </div>
                </div>

                <!-- Bottom Bar (Weight + PRO Tag) -->
                <div class="flex items-center justify-between bg-white px-3 py-2">
                  <div class="flex items-center gap-1 text-xs font-semibold text-slate-700">
                    <span>⚖️</span>
                    <span>{{ boxer.weight }} kg</span>
                  </div>
                  <div class="rounded-full bg-red-600 px-2 py-1 text-xs font-black uppercase text-white">
                    PRO
                  </div>
                </div>
              </div>
            </div>
          </div>
        `
      }).mount(boxersList)
    }
  })
</script>
