<main class="relative min-h-screen overflow-hidden">
  <div class="absolute inset-0 bg-black/40"></div>
  <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('<%= image_url %>')"></div>

  <div class="relative mx-auto flex min-h-screen max-w-7xl items-center px-4 py-24 sm:px-6 lg:px-8">
    <div class="max-w-3xl text-left">
      <% if defined?(subtitle) && subtitle.present? %>
        <p class="mb-6 text-sm uppercase tracking-[0.3em] text-white/70"><%= subtitle %></p>
      <% end %>
      <h1 class="mb-8 text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
        <%= title %>
      </h1>
      <% if defined?(description) && description.present? %>
        <p class="mb-10 max-w-2xl text-lg leading-8 text-slate-200 sm:text-xl">
          <%= description %>
        </p>
      <% end %>
      <% if defined?(button_text) && button_text.present? && defined?(button_link) && button_link.present? %>
        <%= link_to button_text, button_link, class: "inline-flex rounded-full bg-white px-8 py-3 text-sm font-semibold text-black shadow-lg shadow-black/20 transition hover:bg-slate-100" %>
      <% end %>
    </div>
  </div>
</main>
