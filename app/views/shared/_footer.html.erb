<footer class="bg-[#ee1D23] text-white">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:px-8 lg:grid-cols-4">
    <div>
      <h2 class="mb-4 text-lg font-semibold uppercase tracking-[0.2em]">Indirizzo</h2>
      <p class="text-sm leading-7 text-slate-200"><%= @gym_info.gym_name %></p>
      <p class="text-sm leading-7 text-slate-200"><%= @gym_info.gym_subaddress %></p>
      <p class="text-sm leading-7 text-slate-200"><%= @gym_info.gym_address %></p>
      <p class="text-sm leading-7 text-slate-200"><%= @gym_info.zip_code %> <%= @gym_info.city %></p>
      <p class="mt-2 text-sm leading-7 text-slate-200">Tel. <%= @gym_info.mobile_phone %></p>
      <p class="text-sm leading-7 text-slate-200">Mail: <%= @gym_info.info_email %></p>
    </div>

    <div>
      <h2 class="mb-4 text-lg font-semibold uppercase tracking-[0.2em]">Link utili</h2>
      <ul class="space-y-3 text-sm text-slate-200">
        <li><%= link_to "Privacy Policy", "#", class: "hover:text-white" %></li>
        <li><%= link_to "Cookie Policy", "#", class: "hover:text-white" %></li>
      </ul>
    </div>

    <div>
      <h2 class="mb-4 text-lg font-semibold uppercase tracking-[0.2em]">Orari</h2>
      <p class="text-sm leading-7 text-slate-200"><span class="font-semibold text-white">Lun-Ven</span> 7:00 – 22:00</p>
      <p class="text-sm leading-7 text-slate-200"><span class="font-semibold text-white">Sab-Dom</span> 9:00 – 19:30</p>
      <div class="mt-6 flex-wrap items-center gap-4">
        <span class="text-lg font-semibold uppercase tracking-[0.2em]">Seguici</span>
        <div class="flex gap-3" >
        <%= link_to "https://www.instagram.com/boxepiacenza1968", target: "_blank", rel: "noopener noreferrer", class: "text-white transition hover:text-slate-300", aria: { label: "Instagram" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current" aria-hidden="true">
            <path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.5A4.25 4.25 0 0 0 3.5 7.75v8.5A4.25 4.25 0 0 0 7.75 20.5h8.5A4.25 4.25 0 0 0 20.5 16.25v-8.5A4.25 4.25 0 0 0 16.25 3.5h-8.5Zm8.75 2.5a.75.75 0 1 1 0 1.5.75.75 0 0 1 0-1.5Zm-4.25 1.25a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11Zm0 1.5a4 4 0 1 0 0 8 4 4 0 0 0 0-8Z"/>
          </svg>
        <% end %>
        <%= link_to "https://www.facebook.com/boxepiacenza", target: "_blank", rel: "noopener noreferrer", class: "text-white transition hover:text-slate-300", aria: { label: "Facebook" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-6 w-6 fill-current" aria-hidden="true">
            <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z" />
          </svg>
        <% end %>
        </div>
      </div>
    </div>

    <div>
      <h2 class="mb-4 text-lg font-semibold uppercase tracking-[0.2em]">Affiliazioni</h2>
      <div class="grid gap-4">
        <div class="h-14 rounded-lg bg-slate-800"></div>
        <div class="h-14 rounded-lg bg-slate-800"></div>
        <div class="h-14 rounded-lg bg-slate-800"></div>
      </div>
    </div>
  </div>
  <div class="border-t border-slate-800 px-4 py-6 text-center text-sm text-white sm:px-6 lg:px-8">
    A.S.D Boxe Piacenza – C.F. 1234567910 – P.IVA 12345678901
  </div>
</footer>
