<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        color: #333;
        line-height: 1.6;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: #f9f9f9;
        border-radius: 8px;
      }
      .header {
        border-bottom: 3px solid #ee1D23;
        padding-bottom: 20px;
        margin-bottom: 30px;
      }
      .header h1 {
        margin: 0;
        color: #ee1D23;
        font-size: 28px;
      }
      .content {
        background-color: white;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 20px;
      }
      .field {
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
      }
      .field:last-child {
        border-bottom: none;
      }
      .label {
        font-weight: bold;
        color: #ee1D23;
        font-size: 14px;
        text-transform: uppercase;
        margin-bottom: 5px;
      }
      .value {
        color: #555;
        font-size: 16px;
        word-break: break-word;
      }
      .message-body {
        background-color: #f9f9f9;
        padding: 15px;
        border-left: 4px solid #ee1D23;
        border-radius: 4px;
        margin-top: 10px;
      }
      .footer {
        font-size: 12px;
        color: #999;
        text-align: center;
        padding-top: 20px;
        border-top: 1px solid #eee;
        margin-top: 30px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <h1>Nuovo Messaggio di Contatto</h1>
        <p>Da ASD Boxe Piacenza</p>
      </div>

      <div class="content">
        <div class="field">
          <div class="label">Nome e Cognome</div>
          <div class="value"><%= @name %> <%= @lastname %></div>
        </div>

        <div class="field">
          <div class="label">Email</div>
          <div class="value">
            <a href="mailto:<%= @email %>"><%= @email %></a>
          </div>
        </div>

        <div class="field">
          <div class="label">Messaggio</div>
          <div class="message-body">
            <%= simple_format(@message) %>
          </div>
        </div>
      </div>

      <div class="footer">
        <p>Questo è un messaggio automatico da parte del modulo contatti di ASD Boxe Piacenza.</p>
        <p>© <%= Time.current.year %> ASD Boxe Piacenza. Tutti i diritti riservati.</p>
      </div>
    </div>
  </body>
</html>